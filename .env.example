# Ohbot Web GUI — API Keys Template
#
# Copy this file to .env and fill in your actual keys:
#   cp .env.example .env
#   nano .env
#
# NEVER commit your .env file to GitHub — it's already in .gitignore.

# Microsoft Azure Speech (text-to-speech + microphone input)
# Get yours at: https://portal.azure.com → Cognitive Services → Speech
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastus

# OpenAI (AI chat panel)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
